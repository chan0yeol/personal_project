# YouTube API
# 1. Google Cloud Console에서 프로젝트 생성
# 2. YouTube Data API v3 활성화
# 3. OAuth 2.0 클라이언트 ID 생성 (데스크톱 앱)
# 4. credentials.json 다운로드 후 credentials/ 폴더에 저장
YOUTUBE_CREDENTIALS_PATH=/app/credentials/credentials.json
YOUTUBE_TOKEN_PATH=/app/credentials/token.json

# GitHub (스케줄 에이전트가 스크립트를 커밋할 레포)
# 없으면 로컬 scripts/ 폴더만 사용
GITHUB_REPO=
GITHUB_TOKEN=

# 채널 설정
ACTIVE_CHANNELS=news-summary

# 업로드 설정 (KST 기준)
UPLOAD_HOUR=7
UPLOAD_MINUTE=0

# 테스트 모드 (true: 영상 생성만 하고 업로드 안 함)
DRY_RUN=false
