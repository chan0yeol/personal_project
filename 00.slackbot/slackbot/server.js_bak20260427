function getToday() { return formatDate(new Date()); }
function formatDate(d) { return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`; }

// 이번 월요일이 이달 마지막 월요일인지 확인
function isLastMondayOfMonth() {
  const today = new Date();
  if (today.getDay() !== 1) return false; // 월요일이 아니면 false
  const nextMonday = new Date(today);
  nextMonday.setDate(today.getDate() + 7);
  return nextMonday.getMonth() !== today.getMonth();
}

// 월중 근무일수 계산 (월~금, 주말 제외)
function countWorkdays(sdate, edate) {
  let count = 0;
  const cur = new Date(sdate);
  const end = new Date(edate);
  while (cur <= end) {
    const day = cur.getDay();
    if (day !== 0 && day !== 6) count++;
    cur.setDate(cur.getDate() + 1);
  }
  return count;
}
function parseCookies(h) { return (h ?? []).map(c => c.split(";")[0]).join("; "); }
function mergeCookies(a, b) {
  const map = {};
  [...a.split("; "), ...b.split("; ")].forEach(c => { const i = c.indexOf("="); if (i > 0) map[c.slice(0, i).trim()] = c.slice(i + 1).trim(); });
  return Object.entries(map).map(([k, v]) => `${k}=${v}`).join("; ");
}
function formatTime(s, e) { return s && e ? ` (${s}:00 ~ ${e}:00)` : ""; }

