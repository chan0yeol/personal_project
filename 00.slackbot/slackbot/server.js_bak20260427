// 같은 webhook URL을 공유하는 팀 설정을 합쳐서 반환 (중복 발송 방지 + 팀 통합)
function dedupeByWebhook(type) {
  const map = new Map();
  for (const t of teamsData) {
    const enabled = t.notify ? t.notify[type] !== false : t.enabled !== false;
    if (!enabled) continue;
    if (!map.has(t.webhook)) {
      map.set(t.webhook, { ...t, teams: [...t.teams] });
    } else {
      const merged = map.get(t.webhook);
      t.teams.forEach(name => { if (!merged.teams.includes(name)) merged.teams.push(name); });
    }
  }
  return [...map.values()];
}

function getCronFn(id) {
  const thisWeekDates = () => { const d = new Date(); const mon = new Date(d); mon.setDate(d.getDate() - d.getDay() + 1); return Array.from({length:5},(_,i)=>{ const nd = new Date(mon); nd.setDate(mon.getDate()+i); return formatDate(nd); }); };
  const notify = (t, type) => t.notify ? t.notify[type] !== false : t.enabled !== false;
  // 휴가 알림 OFF 멤버 이름 Set
  const vacationExcluded = () => new Set(membersData.filter(m => m.notify?.vacation === false).map(m => m.name));
  const fns = {
    sync: () => syncAndCheckChanges(false),
    vacationWeekly: async () => {
      try {
        const excluded = vacationExcluded();
        const d = thisWeekDates();
        const list = (await fetchVacations(d[0], d[4], true)).filter(i => !excluded.has(i.usName));
        logger(`[이번주휴가] 조회 완료 (${d[0]}~${d[4]}, 전체 ${list.length}명)`);
        for (const t of dedupeByWebhook("vacationWeekly")) {
          const filtered = list.filter(i => t.teams.includes(i.deptName));
          logger(`  → 채널(${t.teams.join(",")}) 발송: ${filtered.length}명${filtered.length ? " | " + filtered.map(i => `${i.usName}(${i.useSdate})`).join(", ") : ""}`);
          await axios.post(t.webhook, buildVacationMessage(d[0], filtered, "이번주 휴가자", true, null, d[4]));
        }
      } catch (err) { logger(`[크론 오류] 이번주 휴가 발송 실패: ${err.message}`, true); }
    },
    vacationDaily: async () => {
      try {
        const excluded = vacationExcluded();
        const today = getToday();
        const list = (await fetchVacations(today, today, true)).filter(i => !excluded.has(i.usName));
        logger(`[오늘휴가] 조회 완료 (${today}, 전체 ${list.length}명)`);
        for (const td of dedupeByWebhook("vacationDaily")) {
          const filtered = list.filter(i => td.teams.includes(i.deptName));
          logger(`  → 채널(${td.teams.join(",")}) 발송: ${filtered.length}명${filtered.length ? " | " + filtered.map(i => `${i.usName}(${i.timeUnitName})`).join(", ") : ""}`);
          await axios.post(td.webhook, buildVacationMessage(today, filtered));
        }
      } catch (err) { logger(`[크론 오류] 오늘 휴가 발송 실패: ${err.message}`, true); }
    },
    roomDaily: async () => {
      try {
        const t = getToday();
        const list = await fetchRooms(t, t, true);
        logger(`[오늘회의실] 조회 완료 (${t}, ${list.length}건)`);
        for (const td of teamsData) {
          if (!notify(td, "roomDaily")) continue;
          logger(`  → 채널(${td.teams.join(",")}) 발송: ${list.length}건${list.length ? " | " + list.map(r => `${r.equipName} ${r.start?.slice(11,16)}~${r.end?.slice(11,16)}`).join(", ") : ""}`);
          await axios.post(td.webhook, buildRoomMessage(t, list));
        }
      } catch (err) { logger(`[크론 오류] 오늘 회의실 발송 실패: ${err.message}`, true); }
    },
    commute: async () => {
      try {
        const now = new Date();
        const today = getToday();
        // 날짜 바뀌면 알림 발송 목록 초기화
        if (commuteNotifiedDate !== today) {
          commuteNotifiedToday = new Set();
          commuteNotifiedDate = today;
        }

        const nowMin = now.getHours() * 60 + now.getMinutes(); // 현재 시각 (분 단위)

        // 출근 알림은 개인 DM → 팀 활성화 여부 무관, 멤버에 등록된 deptId 전체 사용
        const deptIds = [...new Set(membersData.map(m => m.deptId).filter(Boolean))];
        logger(`[출근알림] 체크 대상 deptIds: ${deptIds.join(", ")} (멤버 ${membersData.length}명)`);

        for (const deptId of deptIds) {
          const commuteList = await fetchCommuteStatus(today, deptId);

          for (const record of commuteList) {
            // API 목록에 없거나 이름 없으면 스킵
            if (!record.usName) continue;
            // 이미 출근 등록된 경우 스킵
            if (record.workStartTime) continue;
            // 오늘 이미 알림 보낸 경우 스킵
            const notifyKey = `${deptId}_${record.usName}`;
            if (commuteNotifiedToday.has(notifyKey)) continue;

            // 예정 출근 시간 파싱 (workStime: "09:00", "10:00" 등)
            const workStime = record.workStime;
            if (!workStime) continue;
            const [h, m] = workStime.split(":").map(Number);
            const scheduleMin = h * 60 + m; // 예정 출근 시각 (분 단위)

            // 예정 출근 5분 전부터 알림 대상
            if (nowMin < scheduleMin - 5) continue;

            const member = membersData.find(mb => mb.name === record.usName && mb.deptId === deptId);
            if (!member?.slackId) { logger(`[출근알림] ${record.usName} - 슬랙 ID 없음`); continue; }
            // 멤버 개별 출근알림 비활성화 시 스킵
            if (member.notify?.commute === false) { logger(`[출근알림] ${record.usName} - 출근알림 OFF`); continue; }

            await sendSlackDM(member.slackId, `안녕하세요 ${record.usName}님 :wave:\n아직 *출근 등록*이 되지 않았습니다. 확인 후 등록 부탁드립니다!\nhttps://unipost.co.kr/portal/my-service`);
            commuteNotifiedToday.add(notifyKey);
            logger(`[출근알림] DM 발송: ${record.usName} (예정: ${workStime}, 현재: ${String(now.getHours()).padStart(2,"0")}:${String(now.getMinutes()).padStart(2,"0")})`);
          }
        }
      } catch (err) { logger(`[크론 오류] 출근 알림 실패: ${err.message}`, true); }
    },
    monthlyCommute: async () => {
      if (!isLastMondayOfMonth()) { logger(`[월말출근리포트] 마지막 월요일 아님 - 스킵`); return; }
      try {
        const today = new Date();
        const year = today.getFullYear();
        const month = String(today.getMonth() + 1).padStart(2, "0");
        const firstDay = `${year}-${month}-01`;
        const lastDay = getToday();
        const totalWorkdays = countWorkdays(firstDay, lastDay);

        // 휴가 데이터 조회 (월 전체)
        const vacList = await fetchVacations(firstDay, lastDay, false);
        // { "홍길동": Set(["2026-04-03", "2026-04-04", ...]) } 형태로 정리
        const vacMap = {};
        for (const v of vacList) {
          if (!v.usName || !v.useSdate) continue;
          if (!vacMap[v.usName]) vacMap[v.usName] = new Set();
          // 연차(일 단위): useSdate ~ useEdate 범위의 모든 날짜 추가
          const sd = new Date(v.useSdate); const ed = new Date(v.useEdate || v.useSdate);
          for (let d = new Date(sd); d <= ed; d.setDate(d.getDate() + 1)) {
            vacMap[v.usName].add(formatDate(d));
          }
        }

        // 팀장만 추출
        const leaders = membersData.filter(m => m.isLeader && m.slackId);
        if (!leaders.length) { logger(`[월말출근리포트] 등록된 팀장 없음`); return; }

        for (const leader of leaders) {
          const teamMembers = membersData.filter(m => m.teamName === leader.teamName && m.deptId === leader.deptId);
          if (!teamMembers.length) continue;

          const rawList = await fetchCommuteRange(firstDay, lastDay, leader.deptId);

          // 날짜별 멤버 출퇴근 기록 정리
          const memberDayMap = {}; // { name: { "2026-04-01": { inList: true, checkedIn: true }, ... } }
          for (const record of rawList) {
            if (!record.usName || !record.workDate) continue;
            const dateKey = `${record.workDate.slice(0,4)}-${record.workDate.slice(4,6)}-${record.workDate.slice(6,8)}`;
            // 주말 제외
            const dow = new Date(dateKey).getDay();
            if (dow === 0 || dow === 6) continue;
            if (!memberDayMap[record.usName]) memberDayMap[record.usName] = {};
            memberDayMap[record.usName][dateKey] = { inList: true, checkedIn: !!record.workStartTime };
          }

          const lines = teamMembers.map(m => {
            const dayInfo = memberDayMap[m.name] || {};
            const myVac = vacMap[m.name] || new Set();
            // API 목록에 있고(=평일 근무 대상일) 출근 안 했고, 해당 날짜에 휴가가 아닌 경우만
            const missedDates = [];
            for (const [date, info] of Object.entries(dayInfo)) {
              if (info.inList && !info.checkedIn && !myVac.has(date)) missedDates.push(date);
            }
            missedDates.sort();
            if (!missedDates.length) return `*${m.name}*: 미등록 없음`;
            return `*${m.name}*: 미등록 ${missedDates.length}일\n${missedDates.map(d => `    - ${d}`).join("\n")}`;
          }).join("\n\n");

          const missedSummary = teamMembers.map(m => {
            const dayInfo = memberDayMap[m.name] || {};
            const myVac = vacMap[m.name] || new Set();
            const cnt = Object.entries(dayInfo).filter(([date, info]) => info.inList && !info.checkedIn && !myVac.has(date)).length;
            return `${m.name}:${cnt}일`;
          }).join(", ");
          logger(`[월말출근리포트] ${leader.teamName} 팀장(${leader.name})(${leader.slackId}) DM 발송 | ${missedSummary}`);
          const msg = `📊 *${leader.teamName} ${year}년 ${month}월 출근 미등록 현황*\n\n${lines}\n\n_기준일: ${firstDay} ~ ${lastDay}_`;
          await sendSlackDM(leader.slackId, msg);
        }
      } catch (err) { logger(`[크론 오류] 월말 출근 리포트 실패: ${err.message}`, true); }
    },
    sessionKeep: async () => {
      try { await axios.get(SESSION_KEEP_URL, { headers: { Cookie: avsCookie }, validateStatus: s => true }); } catch { await loginAvs().catch(() => {}); }
      try { await axios.get(GW_SESSION_URL, { headers: { Cookie: gwCookie }, validateStatus: s => true }); } catch { await loginGw().catch(() => {}); }
    },
    logReset: () => { try { fs.writeFileSync(LOG_PATH, "", "utf8"); logger("로그 파일 초기화"); } catch (e) {} },
  };
  return fns[id];
}

function initCrons() {
  for (const cfg of cronSettings) {
    const fn = getCronFn(cfg.id);
    if (!fn) continue;
    if (cronTasks[cfg.id]) cronTasks[cfg.id].stop();
    const opts = cfg.noTimezone ? undefined : { timezone: "Asia/Seoul" };
    try {
      cronTasks[cfg.id] = cron.schedule(cfg.schedule, fn, opts);
      if (!cfg.enabled) cronTasks[cfg.id].stop();
      logger(`크론 등록: ${cfg.id} (${cfg.schedule}) ${cfg.enabled ? "활성" : "비활성"}`);
    } catch (err) {
      // 잘못된 스케줄 → 디폴트로 복구
      const def = DEFAULT_CRON_SETTINGS.find(d => d.id === cfg.id);
      if (def) {
        logger(`크론 스케줄 오류 (${cfg.id}: "${cfg.schedule}") → 디폴트(${def.schedule})로 복구`, true);
        cfg.schedule = def.schedule;
        cronTasks[cfg.id] = cron.schedule(cfg.schedule, fn, opts);
        if (!cfg.enabled) cronTasks[cfg.id].stop();
        saveSettings();
      } else {
        logger(`크론 등록 실패 (${cfg.id}): ${err.message}`, true);
      }
    }
  }
}

