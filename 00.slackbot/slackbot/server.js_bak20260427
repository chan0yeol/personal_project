      return res.json({ ok: true, message: "회의실 변동 샘플 DM 발송" });
    }
    if (type === "commute") {
      await sendSlackDM(slackId, `[테스트] 출근 미등록 알림\n안녕하세요! :wave:\n아직 *출근 등록*이 되지 않았습니다. 확인 후 등록 부탁드립니다!\nhttps://unipost.co.kr/portal/my-service\n\n_테스트 발송 · ${ts}_`);
      logger(`[알림테스트] commute 샘플 발송 완료`);
      return res.json({ ok: true, message: "출근 미등록 샘플 DM 발송" });
    }
    if (type === "monthlyCommute") {
      const now = new Date();
      const year = now.getFullYear();
      const month = String(now.getMonth() + 1).padStart(2, "0");
      const firstDay = `${year}-${month}-01`;
      const lastDay = today;
      const deptIds = [...new Set(membersData.map(m => m.deptId).filter(Boolean))];
      const vacList = await fetchVacations(firstDay, lastDay, false);
      const vacMap = {};
      for (const v of vacList) {
        if (!v.usName || !v.useSdate) continue;
        if (!vacMap[v.usName]) vacMap[v.usName] = new Set();
        const sd = new Date(v.useSdate); const ed = new Date(v.useEdate || v.useSdate);
        for (let d = new Date(sd); d <= ed; d.setDate(d.getDate() + 1)) { vacMap[v.usName].add(formatDate(d)); }
      }
      let report = `[테스트] 📊 ${year}년 ${month}월 출근 미등록 현황\n`;
      for (const deptId of deptIds) {
        const rawList = await fetchCommuteRange(firstDay, lastDay, deptId);
        const memberDayMap = {};
        for (const record of rawList) {
          if (!record.usName || !record.workDate) continue;
          const dateKey = `${record.workDate.slice(0,4)}-${record.workDate.slice(4,6)}-${record.workDate.slice(6,8)}`;
          const dow = new Date(dateKey).getDay();
          if (dow === 0 || dow === 6) continue;
          if (!memberDayMap[record.usName]) memberDayMap[record.usName] = {};
          memberDayMap[record.usName][dateKey] = { inList: true, checkedIn: !!record.workStartTime };
        }
        const deptMembers = membersData.filter(m => m.deptId === deptId);
        for (const m of deptMembers) {
          const dayInfo = memberDayMap[m.name] || {};
          const myVac = vacMap[m.name] || new Set();
          const missed = [];
          for (const [date, info] of Object.entries(dayInfo)) {
            if (info.inList && !info.checkedIn && !myVac.has(date)) missed.push(date);
          }
          missed.sort();
          report += missed.length ? `\n*${m.name}* (${m.teamName}): 미등록 ${missed.length}일\n${missed.map(d => `    - ${d}`).join("\n")}` : `\n*${m.name}* (${m.teamName}): 미등록 없음`;
        }
      }
      report += `\n\n_기준일: ${firstDay} ~ ${lastDay}_`;
      await sendSlackDM(slackId, report);
      logger(`[알림테스트] monthlyCommute 발송 완료 (${deptIds.length}개 부서)`);
      return res.json({ ok: true, message: `월말 출근 리포트 DM 발송` });
    }
    res.status(400).json({ error: `알 수 없는 타입: ${type}` });
  } catch (err) { logger(`[알림테스트] ${type} 실패: ${err.message}`, true); res.status(500).json({ error: err.message }); }
});

